{
  "version": 2,
  // root outputDirectory so Vercel knows where to serve files
  "outputDirectory": "frontend/dist",
  "builds": [
    { "src": "frontend/package.json", "use": "@vercel/static-build", "config": { "distDir": "frontend/dist" } }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/frontend/dist/$1" }
  ]
}