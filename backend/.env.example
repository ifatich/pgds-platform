# Salin file ini menjadi .env dan isi nilainya

# Path ke database SQLite (relatif dari folder prisma/)
DATABASE_URL="file:../pgds.db"

# Secret untuk JWT — wajib diganti dengan string random yang kuat
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="ganti-dengan-string-random-yang-kuat"

# Port backend (default: 3001)
PORT=3001

# URL frontend untuk konfigurasi CORS
# Development: http://localhost:5173
# Production: https://yourdomain.com
FRONTEND_URL="http://localhost:5173"
